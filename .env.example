# App Settings
ENV=development
PROJECT_NAME=FinRAG-Platform
LOG_LEVEL=INFO

# Database Settings
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/finrag
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=mock-vector-db-api-key
REDIS_URL=redis://localhost:6379/0

# Storage Settings
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# LLM Providers (Strict Zero Data Retention)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Embedding & Chunking Settings
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
QDRANT_COLLECTION_NAME=finrag_chunks

# JWT Security Secrets
SECRET_KEY=your-super-secret-cryptographic-signing-key-32-chars-min
