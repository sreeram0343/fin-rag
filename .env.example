# App Settings
ENV=development
PROJECT_NAME=FinRAG-Platform
LOG_LEVEL=INFO

# Database Settings
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/finrag
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=mock-vector-db-api-key
REDIS_URL=redis://localhost:6379/0

# Storage Settings
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# LLM Providers (Strict Zero Data Retention)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# JWT Security Secrets
SECRET_KEY=your-super-secret-cryptographic-signing-key-32-chars-min
